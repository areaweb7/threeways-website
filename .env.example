# Sanity（公開クライアント用。Studio から書き込む場合は SANITY_API_TOKEN を Vercel に設定）
PUBLIC_SANITY_PROJECT_ID=w9q1rwod
PUBLIC_SANITY_DATASET=production

# LINE 公式アカウント — クライアントの正式 URL をそのまま設定してください
PUBLIC_LINE_URL=https://line.me/R/ti/p/

# お問い合わせフォーム（Formspree: https://formspree.io でフォーム作成後、ID を設定）
# フォーム未設定時の案内メールは仮で mail@areaweb.jp（contact ページの mailto）
# PUBLIC_FORMSPREE_FORM_ID=xxxxxxxx
# またはフル URL:
# PUBLIC_FORMSPREE_ENDPOINT=https://formspree.io/f/xxxxxxxx

# LINE QR 画像（任意） public/ に配置した画像パス
# PUBLIC_LINE_QR_SRC=/line-qr.png

# スタッフ写真: public/staff/ に配置し、index.astro の team 配列で img を指定（現状は /placeholders/staff.svg）
# 施工ギャラリー: public/ または Sanity の画像へ順次差し替え
