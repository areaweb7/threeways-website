---
// src/pages/blog/index.astro — ブログ一覧
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { client } from '../../lib/sanity';

let posts: any[] = [];
try {
  posts = await client.fetch(`
    *[_type == "post"] | order(publishedAt desc) {
      _id, title, slug, category, summary, publishedAt,
      "mainImage": mainImage.asset->url,
    }
  `);
} catch(e) {}
---

<Layout title="ブログ・お知らせ | THREEWAYS" description="THREEWAYSからのお知らせ・スタッフブログ・カスタム事例レポートをお届けします。">
  <Header />

  <section class="pt-[62px] bg-[#0a0a0a]">
    <div class="relative h-[220px] overflow-hidden flex items-end"
         style="background-image:url('/cars/car8.jpg');background-size:cover;background-position:center;">
      <div class="absolute inset-0" style="background:rgba(10,10,10,.80)"></div>
      <div class="relative z-10 px-[5%] pb-10 w-full">
        <nav class="text-xs text-[#555] mb-3">
          <a href="/" class="hover:text-[#e85c00] transition-colors">TOP</a>
          <span class="mx-2">/</span>
          <span class="text-[#888]">ブログ・お知らせ</span>
        </nav>
        <p class="text-[.68rem] tracking-[.3em] text-[#e85c00] uppercase mb-2">Blog &amp; News</p>
        <h1 class="text-[clamp(1.8rem,4vw,3rem)] font-black tracking-wide text-white">ブログ・お知らせ</h1>
      </div>
    </div>
  </section>

  <section class="py-14 px-[5%] bg-[#0a0a0a] min-h-[60vh]">
    {posts.length === 0 ? (
      <div class="text-center py-24 text-[#444]">
        <p class="text-5xl mb-6">📝</p>
        <p class="text-lg font-bold text-[#666] mb-3">記事を準備中です</p>
        <p class="text-sm text-[#444]">
          <a href="https://threeways-gifu.sanity.studio/" target="_blank" rel="noopener"
             class="text-[#e85c00] hover:underline">管理画面</a>から記事を追加してください
        </p>
      </div>
    ) : (
      <div style="display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:1.5rem;">
        {posts.map((p: any) => (
          <a href={`/blog/${p.slug?.current ?? p.slug}/`}
             style="text-decoration:none;color:inherit;"
             class="group bg-[#111] border border-[#222] overflow-hidden hover:border-[#e85c00] transition-all duration-300 block">
            {p.mainImage && (
              <div class="overflow-hidden" style="aspect-ratio:16/9;">
                <img src={p.mainImage} alt={p.title} loading="lazy"
                     class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
              </div>
            )}
            <div class="p-5">
              {p.category && (
                <span class="inline-block bg-[#e85c00] text-white text-[.6rem] font-black px-2 py-[2px] tracking-widest mb-3">
                  {p.category}
                </span>
              )}
              <p class="text-[.65rem] text-[#444] mb-2 font-mono">
                {p.publishedAt ? new Date(p.publishedAt).toLocaleDateString('ja-JP') : ''}
              </p>
              <h2 class="font-black text-[.92rem] leading-snug mb-3 text-[#f0f0f0] group-hover:text-[#e85c00] transition-colors">
                {p.title}
              </h2>
              {p.summary && (
                <p class="text-[#666] text-xs leading-relaxed"
                   style="display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;">
                  {p.summary}
                </p>
              )}
              <div class="text-[.72rem] text-[#e85c00] font-bold mt-4 border-t border-[#1e1e1e] pt-3">
                続きを読む →
              </div>
            </div>
          </a>
        ))}
      </div>
    )}
  </section>

  <Footer />
</Layout>
