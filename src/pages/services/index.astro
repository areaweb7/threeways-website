---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { servicePages } from '../../data/servicePages';

const lineUrl = import.meta.env.PUBLIC_LINE_URL || 'https://line.me/R/ti/p/';
---

<Layout
  title="サービス一覧 | THREEWAYS"
  description="岐阜のカスタム輸入車専門店 THREEWAYS のサービス一覧。カスタム製作・全塗装・ラッピング・整備車検・販売・買取まで。"
>
  <Header />

  <section class="pt-[62px] bg-[#0a0a0a]">
    <div class="relative h-[220px] overflow-hidden flex items-end"
         style="background-image:url('/cars/car3.jpg');background-size:cover;background-position:center;">
      <div class="absolute inset-0" style="background:rgba(10,10,10,.82)"></div>
      <div class="relative z-10 px-[5%] pb-10 w-full">
        <nav class="text-xs text-[#555] mb-3">
          <a href="/" class="hover:text-[#e85c00] transition-colors">TOP</a>
          <span class="mx-2">/</span>
          <span class="text-[#888]">サービス</span>
        </nav>
        <p class="text-[.68rem] tracking-[.3em] text-[#e85c00] uppercase mb-2">Our Services</p>
        <h1 class="text-[clamp(1.8rem,4vw,3rem)] font-black tracking-wide text-white">サービス一覧</h1>
        <p class="text-[#aaa] text-sm mt-3 max-w-2xl">
          カスタム・塗装・ラッピングから、整備・車検、販売・買取まで。修理・板金・コーティングはグループの <a href="/gtec/" class="text-[#e85c00] hover:underline">G-TEC</a> とも連携しています。
        </p>
      </div>
    </div>
  </section>

  <section class="py-14 px-[5%] bg-[#0a0a0a]">
    <div class="max-w-5xl mx-auto grid sm:grid-cols-2 gap-5">
      {servicePages.map((p) => (
        <a
          href={`/services/${p.slug}/`}
          class="group bg-[#111] border border-[#222] overflow-hidden hover:border-[#e85c00] transition-all duration-300 flex flex-col sm:flex-row text-left"
        >
          <div class="sm:w-[140px] shrink-0 h-[120px] sm:h-auto overflow-hidden">
            <img
              src={p.heroImage}
              alt=""
              loading="lazy"
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
            />
          </div>
          <div class="p-6 flex flex-col flex-1">
            <span class="text-[.6rem] tracking-[.2em] text-[#e85c00] uppercase mb-2">{p.eyebrow}</span>
            <h2 class="font-black text-lg text-white mb-2 group-hover:text-[#e85c00] transition-colors">{p.title}</h2>
            <p class="text-[#666] text-xs leading-relaxed line-clamp-2 flex-1">{p.description}</p>
            <span class="text-[.72rem] text-[#e85c00] font-bold mt-4 border-t border-[#1e1e1e] pt-3">詳しく見る →</span>
          </div>
        </a>
      ))}
    </div>
  </section>

  <section class="py-12 px-[5%] bg-[#111] border-t border-[#252525]">
    <div class="max-w-3xl mx-auto text-center">
      <h2 class="text-lg font-black text-white mb-3">ホイール修理・板金・コーティング</h2>
      <p class="text-[#888] text-sm mb-6 leading-relaxed">
        上記は <strong class="text-[#ccc]">G-TEC</strong> が担当する技術サービスです。ご依頼は THREEWAYS の LINE・お電話で一括受付しています。
      </p>
      <div class="flex flex-wrap gap-4 justify-center">
        <a href="/gtec/" class="bg-[#e85c00] text-white font-black px-8 py-3 text-sm hover:bg-[#ff7520] transition-colors">
          G-TEC サービスを見る
        </a>
        <a href={lineUrl} target="_blank" rel="noopener" class="border border-[#333] text-[#ccc] px-8 py-3 text-sm hover:border-[#e85c00] transition-colors">
          LINE で相談
        </a>
      </div>
    </div>
  </section>

  <section class="py-10 px-[5%] bg-[#0a0a0a]">
    <div class="max-w-3xl mx-auto text-center text-sm text-[#666]">
      <a href="/#services" class="text-[#888] hover:text-[#e85c00] transition-colors">トップページのサービス紹介へ ↓</a>
    </div>
  </section>

  <Footer />
</Layout>
