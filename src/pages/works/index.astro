---
// src/pages/works/index.astro — 施工事例一覧
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';

const works = [
  {
    slug: 'g-class-tiffany-blue',
    title: 'Mercedes-Benz Gクラス ティファニーブルー全塗装',
    category: '全塗装・カスタム',
    tags: ['メルセデス', 'Gクラス', '全塗装', 'カラーチェンジ'],
    img: '/cars/car9.jpg',
    summary: 'オーナー様のこだわりのティファニーブルーに全塗装。ホイールのブラック化とエアロパーツを組み合わせ、唯一無二の1台に仕上げました。',
    date: '2025-11',
  },
  {
    slug: 'g-class-white-custom',
    title: 'Mercedes-Benz Gクラス ホワイト×ブラック カスタム',
    category: 'エアロ・カスタム',
    tags: ['メルセデス', 'Gクラス', 'ホワイト', 'エアロ'],
    img: '/cars/car11.jpg',
    summary: 'ホワイトボディにブラックのエアロパーツを組み合わせたコントラストカスタム。ルーフレールとフェンダーもブラックで統一。',
    date: '2025-10',
  },
  {
    slug: 'g-class-gold-black',
    title: 'Mercedes-Benz Gクラス ゴールド×ブラック ラッピング',
    category: 'ラッピング',
    tags: ['メルセデス', 'Gクラス', 'ラッピング', 'ゴールド'],
    img: '/cars/car6.jpg',
    summary: 'ゴールドとブラックの大胆なツートーンラッピング。存在感抜群の仕上がりでオーナー様に大変ご満足いただきました。',
    date: '2025-09',
  },
  {
    slug: 'maybach-vclass-custom',
    title: 'Mercedes-Benz Maybach Vクラス フルカスタム',
    category: 'フルカスタム',
    tags: ['マイバッハ', 'Vクラス', 'フルカスタム', 'インテリア'],
    img: '/cars/car4.jpg',
    summary: 'エクステリアからインテリアまでフルカスタム。特注シートとアンビエントライトで高級感を極限まで高めた1台。',
    date: '2025-08',
  },
  {
    slug: 'mustang-shelby-gt500',
    title: 'Ford Mustang Shelby GT500 カスタム仕上げ',
    category: 'カスタム・販売',
    tags: ['マスタング', 'シェルビー', 'GT500', 'アメ車'],
    img: '/cars/car5.jpg',
    summary: '希少なシェルビーGT500をベースに、エアロとホイールをカスタム。迫力のフォルムをさらに際立たせました。',
    date: '2025-07',
  },
  {
    slug: 'g-class-all-black',
    title: 'Mercedes-Benz Gクラス オールブラック カスタム',
    category: '全塗装・カスタム',
    tags: ['メルセデス', 'Gクラス', 'ブラック', 'フルカスタム'],
    img: '/cars/car8.jpg',
    summary: 'ボディ・ホイール・エアロすべてをブラックで統一。重厚感と精悍さを両立したオールブラックカスタム。',
    date: '2025-06',
  },
  {
    slug: 'tesla-model3-custom',
    title: 'Tesla Model 3 エアロカスタム',
    category: 'エアロ・カスタム',
    tags: ['テスラ', 'モデル3', 'エアロ', 'EV'],
    img: '/cars/car3.jpg',
    summary: 'EVのテスラにスポーティなエアロパーツをインストール。環境性能と迫力のスタイルを両立した現代的な1台。',
    date: '2025-05',
  },
  {
    slug: 'camaro-zl1-custom',
    title: 'Chevrolet Camaro ZL1 コンバーチブル カスタム',
    category: 'カスタム・販売',
    tags: ['カマロ', 'ZL1', 'コンバーチブル', 'アメ車'],
    img: '/cars/car10.jpg',
    summary: '超希少なZL1コンバーチブルをカスタム仕上げで販売。エアロとホイールのカスタムで存在感をさらにアップ。',
    date: '2025-04',
  },
];

const categories = ['すべて', '全塗装・カスタム', 'エアロ・カスタム', 'ラッピング', 'フルカスタム', 'カスタム・販売'];
---

<Layout title="施工事例 | THREEWAYS" description="THREEWAYSの施工事例一覧。カスタムカー製作・全塗装・ラッピング・エアロカスタムなど、実際の仕上がりをご覧ください。">
  <Header />

  <!-- ページヒーロー -->
  <section class="pt-[62px] bg-[#0a0a0a]">
    <div class="relative h-[280px] overflow-hidden flex items-end">
      <div class="absolute inset-0 bg-cover bg-center bg-[url('/cars/car9.jpg')]"
           style="filter:brightness(.35)"></div>
      <div class="relative z-10 px-[5%] pb-12 w-full">
        <p class="text-[.68rem] tracking-[.3em] text-[#e85c00] uppercase mb-2">Works Gallery</p>
        <h1 class="text-[clamp(2rem,4vw,3.2rem)] font-black tracking-wide">施工事例</h1>
        <p class="text-[#aaa] text-sm mt-2">THREEWAYSが手がけたカスタムカーの実績をご紹介します</p>
      </div>
    </div>
  </section>

  <!-- カテゴリフィルター -->
  <section class="bg-[#111] border-b border-[#252525] sticky top-[62px] z-40">
    <div class="px-[5%] py-4 flex gap-3 overflow-x-auto scrollbar-none" id="filter-bar">
      {categories.map((cat, i) => (
        <button
          data-cat={cat}
          class={`filter-btn whitespace-nowrap text-[.75rem] tracking-wide px-4 py-2 border transition-all ${i === 0 ? 'bg-[#e85c00] border-[#e85c00] text-white' : 'border-[#333] text-[#888] hover:border-[#e85c00] hover:text-[#e85c00]'}`}
        >
          {cat}
        </button>
      ))}
    </div>
  </section>

  <!-- 施工事例グリッド -->
  <section class="py-16 px-[5%] bg-[#0a0a0a] min-h-screen">
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6" id="works-grid">
      {works.map(w => (
        <a
          href={`/works/${w.slug}/`}
          data-category={w.category}
          class="work-card group bg-[#111] border border-[#252525] overflow-hidden
                 hover:border-[#e85c00] hover:-translate-y-1 transition-all duration-300 block"
        >
          <!-- 写真 -->
          <div class="h-[220px] overflow-hidden relative">
            <img
              src={w.img} alt={w.title} loading="lazy"
              class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
            />
            <div class="absolute top-3 left-3 bg-[#e85c00] text-white text-[.62rem] font-black px-2 py-[3px] tracking-widest">
              {w.category}
            </div>
          </div>
          <!-- テキスト -->
          <div class="p-5">
            <p class="text-[.68rem] text-[#555] mb-2">{w.date}</p>
            <h2 class="font-black text-sm leading-snug mb-3 group-hover:text-[#e85c00] transition-colors">
              {w.title}
            </h2>
            <p class="text-[#888] text-xs leading-relaxed mb-4 line-clamp-2">{w.summary}</p>
            <div class="flex flex-wrap gap-1">
              {w.tags.map(t => (
                <span class="text-[.6rem] border border-[#333] text-[#666] px-2 py-[2px]">#{t}</span>
              ))}
            </div>
          </div>
        </a>
      ))}
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 px-[5%] bg-[#111] border-t border-[#252525] text-center">
    <h2 class="text-xl font-black mb-3">あなたの1台もTHREEWAYSで</h2>
    <p class="text-[#888] text-sm mb-8">カスタムのご相談はLINEから。まずはお気軽にどうぞ。</p>
    <div class="flex gap-4 justify-center flex-wrap">
      <a href="/#contact" class="bg-[#e85c00] text-white font-black px-8 py-3 text-sm tracking-wide hover:bg-[#ff7520] transition-colors">
        LINEで無料相談する
      </a>
      <a href="/" class="border border-white/40 text-white px-8 py-3 text-sm tracking-wide hover:border-[#e85c00] hover:text-[#e85c00] transition-all">
        トップに戻る
      </a>
    </div>
  </section>
</Layout>

<script>
// カテゴリフィルター
const buttons = document.querySelectorAll('.filter-btn');
const cards = document.querySelectorAll('.work-card');

buttons.forEach(btn => {
  btn.addEventListener('click', () => {
    const cat = btn.getAttribute('data-cat');

    // ボタンのアクティブ状態
    buttons.forEach(b => {
      b.className = b.className
        .replace('bg-[#e85c00] border-[#e85c00] text-white', '')
        + ' border-[#333] text-[#888]';
    });
    btn.className = btn.className
      .replace('border-[#333] text-[#888]', '')
      + ' bg-[#e85c00] border-[#e85c00] text-white';

    // カードの表示/非表示
    cards.forEach(card => {
      const cardCat = card.getAttribute('data-category');
      if (cat === 'すべて' || cardCat === cat) {
        (card as HTMLElement).style.display = 'block';
      } else {
        (card as HTMLElement).style.display = 'none';
      }
    });
  });
});
</script>
