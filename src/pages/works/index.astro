---
// src/pages/works/index.astro — Sanity連携版
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { client } from '../../lib/sanity';

// Sanityからデータ取得（なければstatic fallback）
let sanityWorks: any[] = [];
try {
  sanityWorks = await client.fetch(`
    *[_type == "work"] | order(publishedAt desc) {
      _id, title, slug, category, tags, summary, publishedAt,
      "mainImage": mainImage.asset->url,
    }
  `);
} catch(e) {
  // Sanityにデータがなければ空配列
}

// Static fallback（Sanityにデータがない間はこちらを使用）
const staticWorks = [
  { slug: 'g-class-tiffany-blue',   title: 'Mercedes-Benz Gクラス ティファニーブルー全塗装',  category: '全塗装・カスタム', tags: ['メルセデス','Gクラス','全塗装'],       img: '/cars/car9.jpg',  summary: 'オーナー様のこだわりのティファニーブルーに全塗装。唯一無二の1台に仕上げました。', date: '2025.11' },
  { slug: 'g-class-white-custom',   title: 'Mercedes-Benz Gクラス ホワイト×ブラック カスタム', category: 'エアロ・カスタム', tags: ['メルセデス','Gクラス','エアロ'],       img: '/cars/car11.jpg', summary: 'ホワイトボディにブラックのエアロを組み合わせたコントラストカスタム。',             date: '2025.10' },
  { slug: 'g-class-gold-black',     title: 'Mercedes-Benz Gクラス ゴールド×ブラック ラッピング', category: 'ラッピング',      tags: ['メルセデス','Gクラス','ラッピング'],   img: '/cars/car6.jpg',  summary: 'ゴールドとブラックの大胆なツートーンラッピング。存在感抜群の仕上がり。',            date: '2025.09' },
  { slug: 'maybach-vclass-custom',  title: 'Mercedes-Benz Maybach Vクラス フルカスタム',        category: 'フルカスタム',    tags: ['マイバッハ','Vクラス','フルカスタム'], img: '/cars/car4.jpg',  summary: 'エクステリアからインテリアまでフルカスタム。高級感を極限まで高めた1台。',           date: '2025.08' },
  { slug: 'mustang-shelby-gt500',   title: 'Ford Mustang Shelby GT500 カスタム仕上げ',           category: 'カスタム・販売',  tags: ['マスタング','シェルビー','GT500'],    img: '/cars/car5.jpg',  summary: '希少なシェルビーGT500をベースにエアロとホイールをカスタム。',                      date: '2025.07' },
  { slug: 'g-class-all-black',      title: 'Mercedes-Benz Gクラス オールブラック カスタム',      category: '全塗装・カスタム', tags: ['メルセデス','Gクラス','ブラック'],    img: '/cars/car8.jpg',  summary: 'ボディ・ホイール・エアロすべてをブラックで統一。重厚感と精悍さを両立。',            date: '2025.06' },
  { slug: 'tesla-model3-custom',    title: 'Tesla Model 3 エアロカスタム',                       category: 'エアロ・カスタム', tags: ['テスラ','モデル3','EV'],             img: '/cars/car3.jpg',  summary: 'EVのテスラにスポーティなエアロパーツをインストール。',                              date: '2025.05' },
  { slug: 'camaro-zl1-custom',      title: 'Chevrolet Camaro ZL1 コンバーチブル カスタム',       category: 'カスタム・販売',  tags: ['カマロ','ZL1','コンバーチブル'],      img: '/cars/car10.jpg', summary: '超希少なZL1コンバーチブルをカスタム仕上げで販売。',                               date: '2025.04' },
];

// Sanityデータがあればそちらを使う
const works = sanityWorks.length > 0
  ? sanityWorks.map((w: any) => ({
      slug: w.slug?.current ?? w.slug,
      title: w.title,
      category: w.category ?? '',
      tags: w.tags ?? [],
      img: w.mainImage ?? '/cars/car9.jpg',
      summary: w.summary ?? '',
      date: w.publishedAt ? w.publishedAt.slice(0,7).replace('-','.') : '',
    }))
  : staticWorks;

const categories = ['すべて', '全塗装・カスタム', 'エアロ・カスタム', 'ラッピング', 'フルカスタム', 'カスタム・販売'];
---

<Layout title="施工事例 | THREEWAYS" description="THREEWAYSの施工事例一覧。カスタムカー製作・全塗装・ラッピング・エアロカスタムなど。">
  <Header />

  <!-- ページヒーロー -->
  <section class="pt-[62px] bg-[#0a0a0a]">
    <div class="relative h-[260px] overflow-hidden flex items-end"
         style="background-image:url('/cars/car9.jpg');background-size:cover;background-position:center 40%;">
      <div class="absolute inset-0" style="background:rgba(10,10,10,.78)"></div>
      <div class="relative z-10 px-[5%] pb-10 w-full">
        <nav class="text-xs text-[#555] mb-3">
          <a href="/" class="hover:text-[#e85c00] transition-colors">TOP</a>
          <span class="mx-2">/</span>
          <span class="text-[#888]">施工事例</span>
        </nav>
        <p class="text-[.68rem] tracking-[.3em] text-[#e85c00] uppercase mb-2 flex items-center gap-2">
          <span class="w-5 h-px bg-[#e85c00] inline-block"></span>Works Gallery
        </p>
        <h1 class="text-[clamp(1.8rem,4vw,3rem)] font-black tracking-wide text-white">施工事例</h1>
        <p class="text-[#aaa] text-sm mt-2">THREEWAYSが手がけたカスタムカーの実績</p>
      </div>
    </div>
  </section>

  <!-- カテゴリフィルター -->
  <div class="bg-[#111] border-b border-[#252525] sticky top-[62px] z-40">
    <div class="px-[5%] py-4 flex gap-2 overflow-x-auto" id="filter-bar"
         style="scrollbar-width:none;-ms-overflow-style:none;">
      {categories.map((cat, i) => (
        <button
          data-cat={cat}
          class:list={[
            'filter-btn whitespace-nowrap text-[.72rem] font-bold tracking-wide px-4 py-2 border transition-all',
            i === 0 ? 'bg-[#e85c00] border-[#e85c00] text-white' : 'border-[#2e2e2e] text-[#777] hover:border-[#e85c00] hover:text-[#e85c00]'
          ]}
        >{cat}</button>
      ))}
    </div>
  </div>

  <!-- 施工事例グリッド（2カラム確定） -->
  <section class="py-14 px-[5%] bg-[#0a0a0a] min-h-[60vh]">
    <div id="works-grid" style="display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:1.5rem;">
      {works.map(w => (
        <a
          href={`/works/${w.slug}/`}
          data-category={w.category}
          class="work-card group bg-[#111111] border border-[#222] overflow-hidden transition-all duration-300 block"
          style="text-decoration:none;color:inherit;"
        >
          <div class="overflow-hidden relative" style="aspect-ratio:16/10;">
            <img src={w.img} alt={w.title} loading="lazy"
                 class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" />
            <div class="absolute top-3 left-3 bg-[#e85c00] text-white text-[.6rem] font-black px-2 py-[3px] tracking-widest">
              {w.category}
            </div>
            <div class="absolute inset-0 bg-[#e85c00] opacity-0 group-hover:opacity-10 transition-opacity duration-300"></div>
          </div>
          <div class="p-5">
            <p class="text-[.65rem] text-[#444] tracking-widest mb-2 font-mono">{w.date}</p>
            <h2 class="font-black text-[.92rem] leading-snug mb-3 text-[#f0f0f0] group-hover:text-[#e85c00] transition-colors">
              {w.title}
            </h2>
            <p class="text-[#666] text-xs leading-relaxed mb-4" style="display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;">
              {w.summary}
            </p>
            <div class="flex flex-wrap gap-1 mb-3">
              {w.tags.map((t: string) => (
                <span class="text-[.6rem] border border-[#2a2a2a] text-[#555] px-2 py-[2px]">#{t}</span>
              ))}
            </div>
            <div class="flex items-center gap-1 text-[.72rem] text-[#e85c00] font-bold mt-3 border-t border-[#1e1e1e] pt-3">
              詳細を見る <span>→</span>
            </div>
          </div>
        </a>
      ))}
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 px-[5%] bg-[#111] border-t border-[#1e1e1e] text-center">
    <p class="text-[.68rem] tracking-[.3em] text-[#e85c00] uppercase mb-3" style="display:flex;align-items:center;justify-content:center;gap:.75rem;">
      <span style="width:1.25rem;height:1px;background:#e85c00;display:inline-block;"></span>Contact
      <span style="width:1.25rem;height:1px;background:#e85c00;display:inline-block;"></span>
    </p>
    <h2 class="text-xl font-black mb-3 text-white">あなたの1台もTHREEWAYSで</h2>
    <p class="text-[#666] text-sm mb-8">カスタムのご相談はLINEから。まずはお気軽にどうぞ。</p>
    <div style="display:flex;gap:1rem;justify-content:center;flex-wrap:wrap;">
      <a href="/contact/" style="background:#e85c00;color:#fff;font-weight:900;padding:.75rem 2rem;font-size:.875rem;letter-spacing:.1em;text-decoration:none;">
        お問い合わせ・LINE
      </a>
      <a href="/" style="border:1px solid #333;color:#aaa;padding:.75rem 2rem;font-size:.875rem;text-decoration:none;">
        トップに戻る
      </a>
    </div>
  </section>

  <Footer />
</Layout>

<style>
  #filter-bar::-webkit-scrollbar { display: none; }
  .work-card:hover { border-color: #e85c00; transform: translateY(-4px); }
</style>

<script>
const buttons = document.querySelectorAll<HTMLButtonElement>('.filter-btn');
const cards   = document.querySelectorAll<HTMLElement>('.work-card');

buttons.forEach(btn => {
  btn.addEventListener('click', () => {
    const cat = btn.dataset.cat ?? 'すべて';
    buttons.forEach(b => {
      b.style.background = '';
      b.style.borderColor = '#2e2e2e';
      b.style.color = '#777';
    });
    btn.style.background = '#e85c00';
    btn.style.borderColor = '#e85c00';
    btn.style.color = '#fff';
    cards.forEach(card => {
      card.style.display = (cat === 'すべて' || card.dataset.category === cat) ? 'block' : 'none';
    });
  });
});
</script>
